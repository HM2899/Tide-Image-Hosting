DATABASE_URL=postgres://tide:tide@postgres:5432/tide
APP_HOST=0.0.0.0
APP_PORT=8080
APP_PUBLIC_PORT=18080
# 公网部署必须改成真实访问地址，例如 http://YOUR_SERVER_IP:18080
PUBLIC_BASE_URL=http://YOUR_SERVER_IP:18080
# 生产环境必须使用足够长的随机密钥
SESSION_SECRET=请替换为至少32位随机字符串
CONFIG_ENCRYPTION_KEY=请替换为至少32位随机字符串
LOCAL_STORAGE_ROOT=/data/storage
LOCAL_STORAGE_PUBLIC_PREFIX=/files
AI_SERVICE_URL=http://127.0.0.1:8080
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=请替换为强密码
AI_PROVIDER_URL=
AI_PROVIDER_API_KEY=

# 第三方登录。回调地址：
# GitHub:  ${PUBLIC_BASE_URL}/api/auth/oauth/github/callback
# Linux.do: ${PUBLIC_BASE_URL}/api/auth/oauth/linuxdo/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
LINUXDO_OAUTH_CLIENT_ID=
LINUXDO_OAUTH_CLIENT_SECRET=
